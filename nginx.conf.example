# 388JL 本地镜像 — Nginx 示例
# 用法：
#   1. 把 root 改成你服务器上的实际路径（本仓库根目录）
#   2. include 或复制 server 块到 nginx.conf
#   3. nginx -t && nginx -s reload

server {
    listen       80;
    server_name  localhost;   # 改成你的域名

    # 项目根目录（含 activity/、static/）
    root F:/2026Code/san_pi_03;
    index index.html;

    charset utf-8;

    # HTML 里写的是 /static/...
    location /static/ {
        alias F:/2026Code/san_pi_03/static/;
        expires 7d;
    }

    # JS 运行时会请求 /assets/、/images/ 等（与线上一致，不在 /static/ 下）
    location /assets/ {
        alias F:/2026Code/san_pi_03/static/assets/;
        expires 7d;
    }
    location /images/ {
        alias F:/2026Code/san_pi_03/static/images/;
        expires 7d;
    }
    location /svg/ {
        alias F:/2026Code/san_pi_03/static/svg/;
        expires 7d;
    }
    location /icons/ {
        alias F:/2026Code/san_pi_03/static/icons/;
        expires 7d;
    }
    location /first/ {
        alias F:/2026Code/san_pi_03/static/first/;
        expires 7d;
    }
    location /second/ {
        alias F:/2026Code/san_pi_03/static/second/;
        expires 7d;
    }
    location /dw/ {
        alias F:/2026Code/san_pi_03/static/dw/;
        expires 7d;
    }

    location = /sw.produce.min.2.1.6.js {
        alias F:/2026Code/san_pi_03/static/sw.produce.min.2.1.6.js;
    }

    # 活动页：/activity/Custom/218/ → activity/Custom/218/index.html
    location /activity/ {
        try_files $uri $uri/ $uri/index.html =404;
    }

    # 可选：根路径跳到 218
    location = / {
        return 302 /activity/Custom/218/;
    }

    # 线上 API 仍走外网，本地不代理也能打开壳子（动态数据可能空）
    # location /api/ { proxy_pass https://api2.h-f-a-4.com/; }
}
